        <di:waypoint x="1025" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="956" y="292" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_Rejected_di" bpmnElement="Flow_A_Rejected">
        <di:waypoint x="950" y="385" />
