        <bpmndi:BPMNLabel>
          <dc:Bounds x="960" y="440" width="59" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A6_di" bpmnElement="Flow_A6">
        <di:waypoint x="1225" y="280" />
        <di:waypoint x="1255" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A7_di" bpmnElement="Flow_A7">
        <di:waypoint x="1225" y="480" />
        <di:waypoint x="1255" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_Express_di" bpmnElement="Participant_Express" isHorizontal="true">
        <dc:Bounds x="155" y="640" width="1700" height="560" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Express_di" bpmnElement="Lane_Express" isHorizontal="true">
        <dc:Bounds x="185" y="640" width="1670" height="560" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_ExpInbox_di" bpmnElement="StartEvent_ExpInbox">
        <dc:Bounds x="220" y="802" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="224" y="845" width="56" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LimitOk_di" bpmnElement="Gateway_LimitOk" isMarkerVisible="true">
        <dc:Bounds x="295" y="795" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="350" y="806" width="79" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Settlement_di" bpmnElement="Task_Settlement">
        <dc:Bounds x="395" y="680" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyBankB_di" bpmnElement="Task_NotifyBankB">
        <dc:Bounds x="630" y="680" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ExpDone_di" bpmnElement="EndEvent_ExpDone">
        <dc:Bounds x="870" y="702" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="856" y="745" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GridlockSearch_di" bpmnElement="Task_GridlockSearch">
        <dc:Bounds x="395" y="880" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_GridlockOk_di" bpmnElement="Gateway_GridlockOk" isMarkerVisible="true">
        <dc:Bounds x="650" y="895" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="706" y="913" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Alert_di" bpmnElement="Task_Alert">
        <dc:Bounds x="750" y="1000" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ThrowEvent_AlertBank_di" bpmnElement="ThrowEvent_AlertBank">
        <dc:Bounds x="960" y="1022" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="946" y="1065" width="50" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IntermediateTimer_2h_di" bpmnElement="IntermediateTimer_2h">
        <dc:Bounds x="1030" y="1022" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1014" y="1065" width="76" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BankPaid_di" bpmnElement="Gateway_BankPaid" isMarkerVisible="true">
        <dc:Bounds x="1100" y="1015" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1054" y="976" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BlockBank_di" bpmnElement="Task_BlockBank">
