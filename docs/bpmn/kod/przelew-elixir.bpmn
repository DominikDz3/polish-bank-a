<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Elixir" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_Elixir">
    <bpmn:participant id="Participant_Klient" name="Klient" />
    <bpmn:participant id="Participant_BankA" name="Bank A" processRef="Process_BankA" />
    <bpmn:participant id="Participant_KIR" name="KIR (jednostka rozliczeniowa ELIXIR)" processRef="Process_KIR" />
    <bpmn:participant id="Participant_BankB" name="Bank B (odbiorca)" />
    <bpmn:messageFlow id="MF_Init" name="POST /api/external-transfers (PIN + JWT)" sourceRef="Participant_Klient" targetRef="StartEvent_BankA" />
    <bpmn:messageFlow id="MF_SendToKir" name="pacs.008 (kanał SFTP)" sourceRef="SendTask_ToKir" targetRef="StartEvent_KirInbox" />
    <bpmn:messageFlow id="MF_KirSettled" name="Status PROCESSED" sourceRef="EndEvent_KirDone" targetRef="CatchEvent_KirResp" />
    <bpmn:messageFlow id="MF_KirRejected" name="Status REJECTED (unwinding)" sourceRef="EndEvent_Unwinding" targetRef="CatchEvent_KirResp" />
    <bpmn:messageFlow id="MF_NotifyBankB" name="MT pacs.002 + uznanie konta odbiorcy" sourceRef="Task_NotifyBankB" targetRef="Participant_BankB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_BankA" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BankA">
      <bpmn:lane id="Lane_BankBackend" name="Backend Bank A">
        <bpmn:flowNodeRef>StartEvent_BankA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Amount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RejAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BlockFunds</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BuildXml</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_ToKir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_KirResp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_KirStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Settled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RejKir</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_BankA" name="Klient zlecił przelew ELIXIR">
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Init" />
    </bpmn:startEvent>
    <bpmn:task id="Task_Validate" name="Walidacja PIN i salda dostępnego">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Amount" name="Kwota poniżej 1 000 000 PLN?">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Ok</bpmn:outgoing>
      <bpmn:outgoing>Flow_A_RejAmt</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_RejAmount" name="Odrzucono: limit ELIXIR przekroczony">
      <bpmn:incoming>Flow_A_RejAmt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_BlockFunds" name="Blokada środków: balance -= amount, blockedFunds += amount">
      <bpmn:incoming>Flow_A_Ok</bpmn:incoming>
      <bpmn:outgoing>Flow_A3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BuildXml" name="Generuj pacs.008 + externalPaymentId ELIX-...">
      <bpmn:incoming>Flow_A3</bpmn:incoming>
      <bpmn:outgoing>Flow_A4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="SendTask_ToKir" name="Wyślij do KIR (status SENT)">
      <bpmn:incoming>Flow_A4</bpmn:incoming>
      <bpmn:outgoing>Flow_A5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchEvent_KirResp" name="Odbiór statusu z KIR (poller)">
      <bpmn:incoming>Flow_A5</bpmn:incoming>
      <bpmn:outgoing>Flow_A6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_KirResp" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_KirStatus" name="Status od KIR?">
      <bpmn:incoming>Flow_A6</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Settled</bpmn:outgoing>
      <bpmn:outgoing>Flow_A_RejKir</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Complete" name="status = PROCESSED, blockedFunds -= amount">
      <bpmn:incoming>Flow_A_Settled</bpmn:incoming>
      <bpmn:outgoing>Flow_A7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Settled" name="Przelew rozliczony">
      <bpmn:incoming>Flow_A7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Return" name="status = REJECTED, balance += amount, blockedFunds -= amount">
      <bpmn:incoming>Flow_A_RejKir</bpmn:incoming>
      <bpmn:outgoing>Flow_A8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_RejKir" name="Przelew odrzucony przez KIR">
      <bpmn:incoming>Flow_A8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartEvent_BankA" targetRef="Task_Validate" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="Task_Validate" targetRef="Gateway_Amount" />
    <bpmn:sequenceFlow id="Flow_A_Ok" name="TAK" sourceRef="Gateway_Amount" targetRef="Task_BlockFunds" />
    <bpmn:sequenceFlow id="Flow_A_RejAmt" name="NIE" sourceRef="Gateway_Amount" targetRef="EndEvent_RejAmount" />
    <bpmn:sequenceFlow id="Flow_A3" sourceRef="Task_BlockFunds" targetRef="Task_BuildXml" />
    <bpmn:sequenceFlow id="Flow_A4" sourceRef="Task_BuildXml" targetRef="SendTask_ToKir" />
    <bpmn:sequenceFlow id="Flow_A5" sourceRef="SendTask_ToKir" targetRef="CatchEvent_KirResp" />
    <bpmn:sequenceFlow id="Flow_A6" sourceRef="CatchEvent_KirResp" targetRef="Gateway_KirStatus" />
    <bpmn:sequenceFlow id="Flow_A_Settled" name="PROCESSED" sourceRef="Gateway_KirStatus" targetRef="Task_Complete" />
    <bpmn:sequenceFlow id="Flow_A_RejKir" name="REJECTED" sourceRef="Gateway_KirStatus" targetRef="Task_Return" />
    <bpmn:sequenceFlow id="Flow_A7" sourceRef="Task_Complete" targetRef="EndEvent_Settled" />
    <bpmn:sequenceFlow id="Flow_A8" sourceRef="Task_Return" targetRef="EndEvent_RejKir" />
  </bpmn:process>
  <bpmn:process id="Process_KIR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_KIR">
      <bpmn:lane id="Lane_KirClearing" name="Rozliczenie sesyjne">
        <bpmn:flowNodeRef>StartEvent_KirInbox</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueueSession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateTimer_Session</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Netting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Liquidity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Settlement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_KirDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Unwinding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Unwinding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyBankB</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_KirInbox" name="Otrzymano pacs.008 od Banku A">
      <bpmn:outgoing>Flow_K1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_KirInbox" />
    </bpmn:startEvent>
    <bpmn:task id="Task_QueueSession" name="Dodaj do kolejki najbliższej sesji">
      <bpmn:incoming>Flow_K1</bpmn:incoming>
      <bpmn:outgoing>Flow_K2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="IntermediateTimer_Session" name="Start sesji (3x dziennie)">
      <bpmn:incoming>Flow_K2</bpmn:incoming>
      <bpmn:outgoing>Flow_K3</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Session" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Netting" name="Wielostronny netting — obliczenie pozycji banków">
      <bpmn:incoming>Flow_K3</bpmn:incoming>
      <bpmn:outgoing>Flow_K4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Liquidity" name="Płynność banku w NBP OK?">
      <bpmn:incoming>Flow_K4</bpmn:incoming>
      <bpmn:outgoing>Flow_K_LiqOk</bpmn:outgoing>
      <bpmn:outgoing>Flow_K_LiqBad</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Settlement" name="Settlement — przesunięcie środków netto między bankami">
      <bpmn:incoming>Flow_K_LiqOk</bpmn:incoming>
      <bpmn:outgoing>Flow_K5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_KirDone" name="Sesja zamknięta + raport">
      <bpmn:incoming>Flow_K6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_KirDone" />
    </bpmn:endEvent>
    <bpmn:task id="Task_Unwinding" name="Unwinding — wykluczenie banku z sesji">
      <bpmn:incoming>Flow_K_LiqBad</bpmn:incoming>
      <bpmn:outgoing>Flow_K7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Unwinding" name="Bank wykluczony z sesji">
      <bpmn:incoming>Flow_K7</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Unwinding" />
    </bpmn:endEvent>
    <bpmn:task id="Task_NotifyBankB" name="Wysłanie komunikatu uznaniowego do Banku B">
      <bpmn:incoming>Flow_K5</bpmn:incoming>
      <bpmn:outgoing>Flow_K6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_K1" sourceRef="StartEvent_KirInbox" targetRef="Task_QueueSession" />
    <bpmn:sequenceFlow id="Flow_K2" sourceRef="Task_QueueSession" targetRef="IntermediateTimer_Session" />
    <bpmn:sequenceFlow id="Flow_K3" sourceRef="IntermediateTimer_Session" targetRef="Task_Netting" />
    <bpmn:sequenceFlow id="Flow_K4" sourceRef="Task_Netting" targetRef="Gateway_Liquidity" />
    <bpmn:sequenceFlow id="Flow_K_LiqOk" name="TAK" sourceRef="Gateway_Liquidity" targetRef="Task_Settlement" />
    <bpmn:sequenceFlow id="Flow_K_LiqBad" name="NIE" sourceRef="Gateway_Liquidity" targetRef="Task_Unwinding" />
    <bpmn:sequenceFlow id="Flow_K5" sourceRef="Task_Settlement" targetRef="Task_NotifyBankB" />
    <bpmn:sequenceFlow id="Flow_K6" sourceRef="Task_NotifyBankB" targetRef="EndEvent_KirDone" />
    <bpmn:sequenceFlow id="Flow_K7" sourceRef="Task_Unwinding" targetRef="EndEvent_Unwinding" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_Elixir">
      <bpmndi:BPMNShape id="Participant_Klient_di" bpmnElement="Participant_Klient" isHorizontal="true">
        <dc:Bounds x="155" y="80" width="1700" height="60" />
