          <dc:Bounds x="1106" y="270" width="63" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_KirStatus_di" bpmnElement="Gateway_KirStatus" isMarkerVisible="true">
