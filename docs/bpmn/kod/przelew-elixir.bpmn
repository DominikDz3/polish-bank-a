        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_KirInbox_di" bpmnElement="StartEvent_KirInbox">
        <dc:Bounds x="220" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="208" y="825" width="60" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_QueueSession_di" bpmnElement="Task_QueueSession">
        <dc:Bounds x="290" y="760" width="160" height="80" />
