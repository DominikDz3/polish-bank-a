        <bpmndi:BPMNLabel>
          <dc:Bounds x="368" y="383" width="184" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_RespIdem_di" bpmnElement="MF_RespIdem">
