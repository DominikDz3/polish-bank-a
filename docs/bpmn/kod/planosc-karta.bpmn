        <di:waypoint x="1020" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="945" y="433" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LimitsBad_di" bpmnElement="Flow_LimitsBad">
        <di:waypoint x="935" y="535" />
        <di:waypoint x="935" y="640" />
        <di:waypoint x="1020" y="640" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="946" y="585" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="1220" y="410" />
        <di:waypoint x="1270" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="1220" y="640" />
        <di:waypoint x="1270" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_PayDetails_di" bpmnElement="MF_PayDetails">
        <di:waypoint x="440" y="140" />
        <di:waypoint x="440" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="465" y="143" width="120" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_AuthReq_di" bpmnElement="MF_AuthReq">
        <di:waypoint x="540" y="220" />
        <di:waypoint x="540" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="432" y="223" width="95" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_AuthResp_di" bpmnElement="MF_AuthResp">
        <di:waypoint x="620" y="240" />
        <di:waypoint x="620" y="220" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="637" y="223" width="126" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_PosResult_di" bpmnElement="MF_PosResult">
